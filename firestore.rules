rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isPublicIdentity(userId) {
      return get(/databases/$(database)/documents/users/$(userId)/identity/profile)
        .data.isPublic == true;
    }

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;

      match /identity/{docId} {
        allow read: if isPublicIdentity(userId)
          || (request.auth != null && request.auth.uid == userId);
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /skills/{skillId} {
        allow read: if isPublicIdentity(userId)
          || (request.auth != null && request.auth.uid == userId);
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /proofs/{proofId} {
        allow read: if isPublicIdentity(userId)
          || (request.auth != null && request.auth.uid == userId)
          || (request.auth != null
            && resource.data.coachId == request.auth.uid);
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null && (
          request.auth.uid == userId
          || (resource.data.coachId == request.auth.uid
            && request.resource.data.coachId == request.auth.uid)
        );
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      match /timeline/{eventId} {
        allow read: if isPublicIdentity(userId)
          || (request.auth != null && request.auth.uid == userId);
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /handles/{handle} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    match /relationships/{relationshipId} {
      allow read: if request.auth != null && (
        resource.data.fromUserId == request.auth.uid
        || resource.data.toUserId == request.auth.uid
      );
      allow create: if request.auth != null
        && request.resource.data.fromUserId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.fromUserId == request.auth.uid
        || resource.data.toUserId == request.auth.uid
      );
    }

    match /verificationRequests/{requestId} {
      allow read: if request.auth != null && (
        resource.data.athleteId == request.auth.uid
        || resource.data.coachId == request.auth.uid
      );
      allow create: if request.auth != null
        && request.resource.data.athleteId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.coachId == request.auth.uid;
    }

    match /coachProfiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
